# Gemini API Key (for development with Gemini Live API)
GOOGLE_API_KEY=your_api_key_here

# Google Cloud settings (for production with Vertex AI)
GOOGLE_CLOUD_PROJECT=livetutor
GOOGLE_CLOUD_LOCATION=us-central1

# Set to TRUE for Vertex AI, FALSE for Gemini Live API
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Server settings
HOST=0.0.0.0
PORT=8080
